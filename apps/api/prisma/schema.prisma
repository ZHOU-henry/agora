generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AgentDefinition {
  id           String   @id
  slug         String   @unique
  name         String
  summary      String
  description  String
  provenanceStatus String   @default("seeded")
  provenanceSummary String  @default("Seeded internal agent metadata.")
  tags         String[]
  constraints  String[]
  trustSignals String[]
  status       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  taskRequests TaskRequest[]
}

model TaskRequest {
  id          String   @id @default(cuid())
  title       String
  description String
  contextNote String?
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agentId String
  agent   AgentDefinition @relation(fields: [agentId], references: [id], onDelete: Restrict)

  runs TaskRun[]
}

model TaskRun {
  id            String   @id @default(cuid())
  status        String
  latestMessage String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  startedAt     DateTime?
  completedAt   DateTime?

  taskRequestId String
  taskRequest   TaskRequest @relation(fields: [taskRequestId], references: [id], onDelete: Cascade)

  events         RunEvent[]
  reviewDecision ReviewDecision?
}

model RunEvent {
  id        String   @id @default(cuid())
  eventType String
  message   String
  createdAt DateTime @default(now())

  taskRunId String
  taskRun   TaskRun @relation(fields: [taskRunId], references: [id], onDelete: Cascade)
}

model ReviewDecision {
  id         String   @id @default(cuid())
  verdict    String
  notes      String?
  reviewedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  taskRunId String  @unique
  taskRun   TaskRun @relation(fields: [taskRunId], references: [id], onDelete: Cascade)
}
