generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ProviderProfile {
  id          String   @id
  slug        String   @unique
  name        String
  summary     String
  description String
  type        String
  website     String?
  tags        String[]
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agents      AgentDefinition[]
  responses   DemandResponse[]
  engagements Engagement[]
}

model AgentDefinition {
  id               String   @id
  slug             String   @unique
  name             String
  summary          String
  description      String
  providerId       String?
  provider         ProviderProfile? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  provenanceStatus String   @default("seeded")
  provenanceSummary String  @default("Seeded internal agent metadata.")
  tags             String[]
  constraints      String[]
  trustSignals     String[]
  status           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  taskRequests TaskRequest[]
}

model TaskRequest {
  id          String   @id @default(cuid())
  title       String
  description String
  contextNote String?
  requesterOrg String?
  industry    String?
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agentId String
  agent   AgentDefinition @relation(fields: [agentId], references: [id], onDelete: Restrict)

  runs       TaskRun[]
  responses  DemandResponse[]
  engagement Engagement?
}

model DemandResponse {
  id               String   @id @default(cuid())
  status           String
  headline         String
  proposalSummary  String
  deliveryApproach String?
  etaLabel         String?
  confidence       String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  providerId String
  provider   ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)

  taskRequestId String
  taskRequest   TaskRequest @relation(fields: [taskRequestId], references: [id], onDelete: Cascade)

  engagement Engagement?

  @@unique([providerId, taskRequestId])
}

model Engagement {
  id               String   @id @default(cuid())
  status           String
  title            String
  summary          String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  taskRequestId String @unique
  taskRequest   TaskRequest @relation(fields: [taskRequestId], references: [id], onDelete: Cascade)

  demandResponseId String @unique
  demandResponse   DemandResponse @relation(fields: [demandResponseId], references: [id], onDelete: Cascade)

  providerId String
  provider   ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
}

model TaskRun {
  id            String   @id @default(cuid())
  status        String
  latestMessage String?
  resultSummary String?
  resultPayload Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  startedAt     DateTime?
  completedAt   DateTime?

  taskRequestId String
  taskRequest   TaskRequest @relation(fields: [taskRequestId], references: [id], onDelete: Cascade)

  events         RunEvent[]
  reviewDecision ReviewDecision?
}

model RunEvent {
  id        String   @id @default(cuid())
  eventType String
  message   String
  createdAt DateTime @default(now())

  taskRunId String
  taskRun   TaskRun @relation(fields: [taskRunId], references: [id], onDelete: Cascade)
}

model ReviewDecision {
  id         String   @id @default(cuid())
  verdict    String
  notes      String?
  reviewedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  taskRunId String  @unique
  taskRun   TaskRun @relation(fields: [taskRunId], references: [id], onDelete: Cascade)
}
