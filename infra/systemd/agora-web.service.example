[Unit]
Description=Agora Web
After=network.target agora-api.service
Wants=network.target

[Service]
Type=simple
User=henry
WorkingDirectory=/srv/agora/apps/web
Environment=PORT=3000
Environment=HOSTNAME=0.0.0.0
Environment=AGORA_INTERNAL_API_BASE_URL=http://127.0.0.1:3001
Environment=AGORA_ACCESS_PASSWORD=CHANGE_ME
Environment=NEXT_TELEMETRY_DISABLED=1
ExecStart=/usr/bin/env pnpm start -- --hostname 0.0.0.0 --port 3000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
